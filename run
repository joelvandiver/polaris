#!/usr/bin/env bash
# build.sh – run helper for building and serving Polaris
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

usage() {
  cat <<'EOF'
Usage: ./build.sh <command>

Commands:
  build        Build polaris-core to web/pkg via wasm-pack
  serve        Serve the web/ directory on http://localhost:8080
  run          Build, then serve
  help         Show this help

Examples:
  ./build.sh build
  ./build.sh serve
  ./build.sh run
EOF
}

build_wasm() {
  echo "Building polaris-core -> WASM..."
  wasm-pack build crates/polaris-core \
    --target web \
    --out-dir "$(pwd)/web/pkg"

  echo "Build complete."
}

serve_web() {
  echo "Serving web/ at http://localhost:8080"
  python3 -m http.server 8080 --directory web
}

command="${1:-help}"

case "$command" in
  build)
    build_wasm
    ;;
  serve)
    serve_web
    ;;
  run)
    build_wasm
    serve_web
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    echo "Unknown command: $command" >&2
    echo "" >&2
    usage
    exit 1
    ;;
esac
