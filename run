#!/bin/bash

help=$(cat << EOF
usage [run <command>]
watch   start tests in watch mode
ci      run ci commands
EOF
)

cmd=$1
shift

case "$cmd" in
    watch) cargo watch -x run ;;
    ci)
        cargo fmt --all
        cargo clippy --workspace --all-targets -- -D warnings
        cargo test --workspace
        ;;
    *) echo "$help"
esac
